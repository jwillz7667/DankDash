{
  "name": "@dankdash/test-utils",
  "version": "0.0.0",
  "private": true,
  "description": "Testcontainers helpers, deterministic seed scenarios, and shared fixtures. Fleshed out in Phase 1.",
  "license": "UNLICENSED",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./scenarios": {
      "types": "./dist/scenarios.d.ts",
      "import": "./dist/scenarios.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src --max-warnings 0",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "@dankdash/config": "workspace:^",
    "@dankdash/db": "workspace:^",
    "@dankdash/types": "workspace:^",
    "drizzle-orm": "^0.45.2",
    "pino": "^9.5.0",
    "postgres": "^3.4.9",
    "uuidv7": "^1.2.1"
  },
  "peerDependencies": {
    "vitest": "^2.1.8"
  }
}
