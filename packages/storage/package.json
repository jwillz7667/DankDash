{
  "name": "@dankdash/storage",
  "version": "0.0.0",
  "private": true,
  "description": "Cloudflare R2 (S3-compatible) object storage adapter — presigned uploads, presigned downloads, public URLs, and lifecycle (delete, exists) helpers. Wraps the AWS SDK v3 so the rest of the codebase never imports it directly.",
  "license": "UNLICENSED",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src --max-warnings 0",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1050.0",
    "@aws-sdk/lib-storage": "^3.1050.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "@dankdash/types": "workspace:*",
    "pino": "^9.5.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@vitest/coverage-v8": "^2.1.9",
    "aws-sdk-client-mock": "^4.1.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
