{
  "name": "@dankdash/pricing",
  "version": "0.0.0",
  "private": true,
  "description": "Order pricing — Minnesota cannabis gross-receipts tax (§ 295.81), state sales tax (§ 297A.62), local sales tax, pass-through fees/tips. Integer cents in, integer cents out, banker's rounding.",
  "license": "UNLICENSED",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src --max-warnings 0",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@dankdash/compliance": "workspace:*",
    "decimal.js": "^10.6.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@vitest/coverage-v8": "^2.1.9",
    "fast-check": "^3.23.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
