{
  "name": "@dankdash/config",
  "version": "0.0.0",
  "private": true,
  "description": "Shared configuration primitives: TypeScript, ESLint, Prettier, env validation, and structured logging.",
  "license": "UNLICENSED",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./env": {
      "types": "./dist/env.d.ts",
      "import": "./dist/env.js"
    },
    "./logger": {
      "types": "./dist/logger.d.ts",
      "import": "./dist/logger.js"
    },
    "./tsconfig.base.json": "./tsconfig.base.json",
    "./eslint.config.js": "./eslint.config.js",
    "./prettier.config.js": "./prettier.config.js"
  },
  "files": [
    "dist",
    "tsconfig.base.json",
    "eslint.config.js",
    "prettier.config.js"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint . --max-warnings 0",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@dankdash/types": "workspace:*",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
