{
  "name": "@dankdash/observability",
  "version": "0.0.0",
  "private": true,
  "description": "Shared observability primitives — OpenTelemetry SDK bootstrap, AsyncLocalStorage request context, pino mixin, Prometheus registry, and Sentry initializer. Consumed by api, realtime, and workers.",
  "license": "UNLICENSED",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./otel": {
      "types": "./dist/otel/index.d.ts",
      "import": "./dist/otel/index.js"
    },
    "./context": {
      "types": "./dist/context/index.d.ts",
      "import": "./dist/context/index.js"
    },
    "./logging": {
      "types": "./dist/logging/index.d.ts",
      "import": "./dist/logging/index.js"
    },
    "./metrics": {
      "types": "./dist/metrics/index.d.ts",
      "import": "./dist/metrics/index.js"
    },
    "./errors": {
      "types": "./dist/errors/index.d.ts",
      "import": "./dist/errors/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src --max-warnings 0",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.218.0",
    "@opentelemetry/instrumentation": "^0.218.0",
    "@opentelemetry/instrumentation-fastify": "^0.57.0",
    "@opentelemetry/instrumentation-http": "^0.218.0",
    "@opentelemetry/instrumentation-ioredis": "^0.66.0",
    "@opentelemetry/instrumentation-pg": "^0.70.0",
    "@opentelemetry/instrumentation-pino": "^0.64.0",
    "@opentelemetry/instrumentation-socket.io": "^0.65.0",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-node": "^0.218.0",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "@sentry/node": "^8.45.0",
    "prom-client": "^15.1.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@vitest/coverage-v8": "^2.1.9",
    "pino": "^9.5.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
