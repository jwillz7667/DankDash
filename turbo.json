{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "stream",
  "globalEnv": ["NODE_ENV", "CI", "NEXT_PUBLIC_API_BASE_URL", "NEXT_PUBLIC_REALTIME_URL"],
  "globalPassThroughEnv": [
    "DATABASE_URL",
    "DATABASE_URL_TEST",
    "REDIS_URL",
    "LOG_LEVEL",
    "AUTH_SECRET",
    "INTERNAL_API_BASE_URL"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"],
      "inputs": ["src/**", "tsconfig.json", "tsconfig.build.json", "package.json"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "inputs": [
        "src/**",
        "test/**",
        "eslint.config.js",
        "tsconfig.json",
        "tsconfig.build.json",
        "package.json"
      ],
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "test/**", "tsconfig.json", "tsconfig.build.json", "package.json"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build"],
      "inputs": [
        "src/**",
        "test/**",
        "vitest.config.ts",
        "tsconfig.json",
        "tsconfig.build.json",
        "package.json"
      ],
      "outputs": ["coverage/**"]
    },
    "test:integration": {
      "dependsOn": ["^build"],
      "cache": false,
      "outputs": []
    },
    "clean": {
      "cache": false
    }
  }
}
