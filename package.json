{
  "name": "dankdash",
  "version": "0.0.0",
  "private": true,
  "description": "DankDash — three-sided cannabis delivery marketplace for the Minnesota adult-use market.",
  "license": "UNLICENSED",
  "type": "module",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.12.3",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md,yaml,yml}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md,yaml,yml}\" --ignore-path .gitignore",
    "security:audit": "audit-ci --config audit-ci.json",
    "security:secrets": "bash ./scripts/verify-no-secrets.sh",
    "security:semgrep": "bash ./scripts/run-semgrep.sh",
    "security:licenses": "bash ./scripts/audit-licenses.sh",
    "prepare": "bash ./scripts/install-git-hooks.sh"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.5.0",
    "@commitlint/config-conventional": "^19.5.0",
    "@dankdash/config": "workspace:*",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "audit-ci": "^7.1.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-import-resolver-typescript": "^3.7.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-unused-imports": "^4.1.4",
    "globals": "^15.14.0",
    "lint-staged": "^15.2.11",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0",
    "vitest": "^2.1.8"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,cjs}": [
      "eslint --fix --max-warnings 0 --no-warn-ignored",
      "prettier --write"
    ],
    "*.{json,md,yaml,yml,css}": [
      "prettier --write"
    ]
  },
  "pnpm": {
    "overrides": {
      "thrift": ">=0.23.0",
      "tmp": ">=0.2.6"
    }
  }
}
