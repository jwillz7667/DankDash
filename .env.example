# =============================================================================
# DankDash environment variables
# =============================================================================
# Copy to `.env` and fill in real values. Anything checked into the repo MUST
# be a placeholder. Required vars are validated at boot by
# `packages/config/src/env.ts` — missing values fail fast with a typed error.
#
# Generate the local-only secrets with:
#   openssl rand -base64 48   # PASSWORD_PEPPER
#   openssl rand -base64 32   # COLUMN_ENCRYPTION_KEY_BASE64
#   ./scripts/gen-jwt-keys.sh # JWT_{PRIVATE,PUBLIC}_KEY_BASE64
# =============================================================================

NODE_ENV=development

# === Database ================================================================
# Default ports match docker-compose.yml (5433 host -> 5432 container).
DATABASE_URL=postgresql://dankdash:dankdash@localhost:5433/dankdash
DATABASE_URL_TEST=postgresql://dankdash:dankdash@localhost:5433/dankdash_test
DATABASE_POOL_SIZE=10
DATABASE_SLOW_QUERY_MS=500

# === Redis ===================================================================
REDIS_URL=redis://localhost:6380

# === Auth ====================================================================
# Generate with ./scripts/gen-jwt-keys.sh (ES256, base64-encoded PEM).
JWT_PRIVATE_KEY_BASE64=
JWT_PUBLIC_KEY_BASE64=
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000
# 32+ bytes of random, e.g. `openssl rand -base64 48`.
PASSWORD_PEPPER=

# === Column-level encryption =================================================
# 32-byte key, base64-encoded. Used for at-rest encryption of PII columns
# (DOB, ID-scan reference, etc.). Rotation requires a re-encrypt migration.
COLUMN_ENCRYPTION_KEY_BASE64=

# === Object storage (Cloudflare R2 in prod, LocalStack S3 locally) ===========
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=dankdash-dev
R2_PUBLIC_BASE_URL=

# === Payments (Aeropay ACH) ==================================================
AEROPAY_CLIENT_ID=
AEROPAY_CLIENT_SECRET=
AEROPAY_WEBHOOK_SECRET=
AEROPAY_API_BASE_URL=https://api.aeropay.com

# === Identity verification (Persona for onboarding, Veriff at delivery) =====
PERSONA_API_KEY=
PERSONA_WEBHOOK_SECRET=
PERSONA_TEMPLATE_ID=
VERIFF_API_KEY=
VERIFF_WEBHOOK_SECRET=

# === Cannabis traceability (Metrc MN tenant) =================================
METRC_API_KEY=
METRC_USER_KEY=
METRC_API_BASE_URL=https://api-mn.metrc.com

# === Maps / geocoding ========================================================
MAPBOX_ACCESS_TOKEN=

# === Comms ===================================================================
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Masked-number Proxy service (driver↔customer comms during a delivery).
TWILIO_PROXY_SERVICE_SID=
# Outbound transactional SMS — set ONE of these. Messaging Service SID is
# preferred (lets Twilio rotate senders); from-number is the fallback for
# environments with a single dedicated long code.
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_FROM_NUMBER=
RESEND_API_KEY=
RESEND_FROM_EMAIL=orders@dankdash.com

# === Apple Push Notifications (APNS) =========================================
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=
APNS_PRIVATE_KEY_BASE64=

# === Observability ===========================================================
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
LOG_LEVEL=debug

# === Process ports ===========================================================
PORT=3000
REALTIME_PORT=3001

# === CORS ====================================================================
# Comma-separated exact-match browser origins allowed to read API responses
# (vendor portal, consumer checkout web). No wildcards. Leave empty to keep
# CORS disabled — the native iOS clients do not need it.
CORS_ALLOWED_ORIGINS=https://portal.dankdash.com,https://app.dankdash.com

# === Feature flags ===========================================================
ENABLE_AEROPAY=true
ENABLE_METRC=false
ENABLE_PERSONA=true
ENABLE_VERIFF=true
ENABLE_TWILIO=true
ENABLE_RESEND=true
# Swagger UI + OpenAPI document at /docs. Non-production always mounts it;
# production mounts it ONLY when this is true. Keep false in prod.
ENABLE_API_DOCS=false
