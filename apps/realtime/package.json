{
  "name": "@dankdash/realtime",
  "version": "0.0.0",
  "private": true,
  "description": "Standalone Socket.io service (namespaces: /customer, /vendor, /driver). Consumes the `dankdash:realtime` Redis Stream and fans out to rooms.",
  "license": "UNLICENSED",
  "type": "module",
  "main": "./dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src --max-warnings 0",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@dankdash/config": "workspace:*",
    "@dankdash/db": "workspace:*",
    "@dankdash/observability": "workspace:*",
    "@dankdash/realtime-events": "workspace:*",
    "@dankdash/types": "workspace:*",
    "@opentelemetry/api": "^1.9.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "drizzle-orm": "^0.45.2",
    "express": "^4.21.2",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "pino": "^9.5.0",
    "prom-client": "^15.1.3",
    "socket.io": "^4.8.1",
    "uuidv7": "^1.2.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.10.2",
    "socket.io-client": "^4.8.1",
    "testcontainers": "^11.14.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
