#!/usr/bin/env bash
# Pre-commit hook: runs lint-staged + gitleaks against the staged files.
# Installed by `pnpm install` via the root `prepare` script, which calls
# `git config core.hooksPath .githooks`.
set -euo pipefail

# Skip on rebases / cherry-picks where staged content is intentionally partial.
if [[ -f "$(git rev-parse --git-path MERGE_MSG)" ]] || \
   [[ -f "$(git rev-parse --git-path CHERRY_PICK_HEAD)" ]] || \
   [[ -f "$(git rev-parse --git-path REBASE_HEAD)" ]]; then
  exit 0
fi

pnpm exec lint-staged --concurrent false

# Block secrets from landing in any commit. The wrapper is permissive
# when gitleaks is not installed locally (CI is the authoritative
# gate), so this is fast feedback for developers who have it.
bash "$(git rev-parse --show-toplevel)/scripts/verify-no-secrets.sh"
