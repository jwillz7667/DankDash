# =============================================================================
# DankDash — production env template
# =============================================================================
# This file documents the variables a production deploy must supply and where
# their real values come from. It is checked into the repo on purpose; the
# actual `.env.production` (gitignored) is materialized on each Railway service
# from secret-manager values, never from this template directly.
#
# Validation gate (launch-checklist §2.3):
#   pnpm --filter @dankdash/api run env-check
#
# The CLI runs `EnvSchema` (shape) and then the production-strict overlay from
# `@dankdash/config` — banned localhost hosts, banned debug log levels, JWT
# key-pair coherence, feature-flag/credential coherence, Twilio sender XOR.
# Exit code 2 = at least one check failed.
#
# Conventions:
#   <FROM:…>     real value lives in the named secret store; never paste here
#   <DEFAULT>    schema default that production is expected to keep
#   <COMPUTED>   derived from another secret (e.g. base64 of a PEM file)
# =============================================================================

NODE_ENV=production

# === Database ================================================================
# Railway Postgres internal address (IPv6-only — see ADR 0007 / project
# memory note on `family: 0` for ioredis). Use the *private* URL so the
# connection stays inside Railway's network. The replica suffix is fine.
DATABASE_URL=<FROM:Railway → service `postgres` → `DATABASE_URL_PRIVATE`>
# Test DB is never set in production; it's a CI-only signal.
# DATABASE_URL_TEST is intentionally unset here.
DATABASE_POOL_SIZE=20
DATABASE_SLOW_QUERY_MS=500
# 30s per-statement cap protects against runaway queries; workers raise
# this in their own env via overrides (see Phase 9 worker config).
DATABASE_STATEMENT_TIMEOUT_MS=30000
DATABASE_IDLE_IN_TXN_TIMEOUT_MS=60000

# === Redis ===================================================================
# Railway Redis internal address. Every ioredis client in the codebase
# already sets `family: 0` so IPv6 resolves correctly.
REDIS_URL=<FROM:Railway → service `redis` → `REDIS_URL_PRIVATE`>

# === Auth ====================================================================
# Generated once with `./scripts/gen-jwt-keys.sh`, stored in 1Password
# vault "DankDash / prod-secrets / jwt". Rotation runbook:
# docs/runbooks/jwt-key-rotation.md (when added). Pair coherence is
# validated by env-check `checkJwtKeyPair`.
JWT_PRIVATE_KEY_BASE64=<FROM:1Password vault `DankDash/prod-secrets/jwt`>
JWT_PUBLIC_KEY_BASE64=<FROM:1Password vault `DankDash/prod-secrets/jwt`>
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000
# Apple §10.4 checkout handoff target — embedded in the iOS handoff
# response, not composed client-side. Must be the apex production host.
CHECKOUT_BASE_URL=https://app.dankdash.com
CHECKOUT_HANDOFF_TTL_SECONDS=300
# 48+ random bytes, generated with `openssl rand -base64 48`. Stored in
# 1Password. Rotation runbook: docs/runbooks/password-pepper-rotation.md.
PASSWORD_PEPPER=<FROM:1Password vault `DankDash/prod-secrets/password-pepper`>

# === Column-level encryption (Restricted-tier PII) ===========================
# 32-byte key, base64-encoded. Wrapped by the Railway-managed master key.
# Rotation = re-encrypt migration; see ADR 0004 (when added) and the
# encryption-key-rotation runbook.
COLUMN_ENCRYPTION_KEY_BASE64=<FROM:Railway secret `COLUMN_ENCRYPTION_KEY_BASE64`>

# === Document-hash pepper (id-scan hashes, KYC refs) =========================
# 32+ bytes, base64. Used to HMAC document IDs before logging — prevents
# a leak of pino logs from being a leak of customer IDs.
DOCUMENT_HASH_PEPPER_BASE64=<FROM:Railway secret `DOCUMENT_HASH_PEPPER_BASE64`>

# === Object storage (Cloudflare R2) ==========================================
# Production bucket is `dankdash-prod` in the dankdash Cloudflare account.
# Token pair has R2 read/write on this bucket only — never use the
# account-wide admin key here.
R2_ACCOUNT_ID=<FROM:Cloudflare → R2 → account ID (public-ish, but treat as secret)>
R2_ACCESS_KEY_ID=<FROM:1Password vault `DankDash/prod-secrets/r2`>
R2_SECRET_ACCESS_KEY=<FROM:1Password vault `DankDash/prod-secrets/r2`>
R2_BUCKET_NAME=dankdash-prod
# CDN front for public R2 assets (product images, COA PDFs). Restricted
# assets (ID scans, COA originals pre-redaction) use signed URLs only.
R2_PUBLIC_BASE_URL=https://cdn.dankdash.com

# === Payments (Aeropay ACH) ==================================================
# Production keys from Aeropay dashboard → "Live" environment. Test/sandbox
# keys are rejected by env-check (`looksLikeTestCredential`). AEROPAY_LIVE
# must also be true to actually move money — see the gateway in
# apps/api/src/modules/drivers/services/aeropay-driver-payout.gateway.ts.
AEROPAY_CLIENT_ID=<FROM:Aeropay dashboard → Live → API credentials>
AEROPAY_CLIENT_SECRET=<FROM:Aeropay dashboard → Live → API credentials>
AEROPAY_WEBHOOK_SECRET=<FROM:Aeropay dashboard → Live → webhook config>
AEROPAY_API_BASE_URL=https://api.aeropay.com
# Gates the live payout path. Flip true ONLY after KYC + bank-link work
# (Phase 13 follow-up) is shipped; before then the gateway records intent
# and returns a stub receipt.
AEROPAY_LIVE=true

# === Identity verification ===================================================
# Persona handles onboarding (driver + dispensary KYC). Veriff handles
# at-handoff customer ID verification per the cannabis compliance rule.
# Production templates / environments only — sandbox URLs trip env-check.
PERSONA_API_KEY=<FROM:Persona dashboard → Production → API keys>
PERSONA_WEBHOOK_SECRET=<FROM:Persona dashboard → Production → webhooks>
PERSONA_TEMPLATE_ID=<FROM:Persona dashboard → Production → "MN driver KYC v3" template id>
VERIFF_API_KEY=<FROM:Veriff dashboard → Live → integration credentials>
VERIFF_WEBHOOK_SECRET=<FROM:Veriff dashboard → Live → webhook signing secret>
VERIFF_API_BASE_URL=https://stationapi.veriff.com

# === Cannabis traceability (Metrc MN tenant) =================================
# Metrc API base differs per state — MN is api-mn.metrc.com. The user-key
# is per-license-holder; we run a single MN license at launch. ENABLE_METRC
# defaults false because Metrc nightly reconciliation is a Phase 14 task
# (per ADR 0009). Flip to true once that lands.
METRC_API_KEY=<FROM:Metrc admin → API key (license holder)>
METRC_USER_KEY=<FROM:Metrc admin → user key (license holder)>
METRC_API_BASE_URL=https://api-mn.metrc.com

# === Maps / geocoding ========================================================
# Mapbox public token (pk.*); rate-limited per token. Routes / geocoding
# both billed against this. Tokens with `styles:tiles` + `geocoding:read`
# scopes; production token is restricted to the apex domains.
MAPBOX_ACCESS_TOKEN=<FROM:Mapbox account → access tokens → "prod-api">

# === Comms ===================================================================
# Twilio: Account SID + Auth Token from main project. Proxy service handles
# masked-number calls between driver and customer during a delivery.
# For outbound transactional SMS, set EXACTLY ONE of MESSAGING_SERVICE_SID
# (preferred) or FROM_NUMBER — env-check enforces XOR.
TWILIO_ACCOUNT_SID=<FROM:Twilio console → Account → API credentials>
TWILIO_AUTH_TOKEN=<FROM:Twilio console → Account → API credentials>
TWILIO_PROXY_SERVICE_SID=<FROM:Twilio console → Proxy → service SID>
TWILIO_MESSAGING_SERVICE_SID=<FROM:Twilio console → Messaging → service SID (preferred)>
# TWILIO_FROM_NUMBER intentionally unset — using MESSAGING_SERVICE_SID.
# Resend handles transactional email (receipts, KYC notices).
RESEND_API_KEY=<FROM:Resend dashboard → API keys → "prod-api">
RESEND_FROM_EMAIL=orders@dankdash.com

# === Apple Push Notifications (APNS) =========================================
# Token-based auth (p8) preferred over cert-based. Generated in App Store
# Connect → Users and Access → Integrations → Keys. The p8 file is base64'd
# here so it can live in a single env var.
APNS_KEY_ID=<FROM:App Store Connect → key ID for the APNS p8>
APNS_TEAM_ID=<FROM:Apple Developer → team ID (matches DankDash dev team)>
APNS_BUNDLE_ID=com.dankdash.consumer
APNS_PRIVATE_KEY_BASE64=<COMPUTED: `base64 -w0 < AuthKey_XXXXXXXXXX.p8` from the p8 download>

# === Observability ===========================================================
# Both required in production (launch-checklist §8, enforced by env-check).
# Sentry DSN is for the API project; iOS apps have their own DSNs set in
# the Xcode build settings (not via this file).
SENTRY_DSN=<FROM:Sentry → project `dankdash-api` → Client Keys (DSN)>
# OTLP collector address — Grafana Cloud, Honeycomb, or self-hosted. Must
# accept OTLP/HTTP at /v1/traces and /v1/metrics.
OTEL_EXPORTER_OTLP_ENDPOINT=<FROM:Grafana Cloud → OTLP endpoint URL>
LOG_LEVEL=info

# === Process ports ===========================================================
# Railway binds these from inside the container; the public domain is
# rewritten by the Railway proxy. Keep these defaults.
PORT=3000
REALTIME_PORT=3001
WORKERS_METRICS_PORT=3002

# === Feature flags ===========================================================
# Coherence with the credentials above is checked by env-check
# (`checkFeatureFlagCoherence`).
ENABLE_AEROPAY=true
ENABLE_METRC=false
ENABLE_PERSONA=true
ENABLE_VERIFF=true
